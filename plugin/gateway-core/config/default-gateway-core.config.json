{
  "llmDecisionRuntime": {
    "enabled": true,
    "mode": "assist",
    "hookModes": {
      "task-resume-info": "assist",
      "todo-continuation-enforcer": "assist"
    },
    "command": "opencode",
    "model": "github-copilot/gpt-5-mini",
    "timeoutMs": 4000,
    "failureCooldownMs": 120000,
    "maxPromptChars": 1200,
    "maxContextChars": 2400,
    "enableCache": true,
    "cacheTtlMs": 300000,
    "maxCacheEntries": 256
  }
}
